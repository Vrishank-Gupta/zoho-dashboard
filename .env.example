QUBO_APP_HOST=127.0.0.1
QUBO_APP_PORT=8000
QUBO_APP_RELOAD=true
QUBO_SERVE_FRONTEND=false
QUBO_USE_SAMPLE_DATA=false
QUBO_ANALYTICS_BACKEND=clickhouse
QUBO_PIPELINE_RECREATE_TABLES=false
QUBO_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.netlify.app

# Remote Zoho ticket source
QUBO_ZOHO_DB_HOST=your-zoho-host
QUBO_ZOHO_DB_PORT=3306
QUBO_ZOHO_DB_USER=your-zoho-user
QUBO_ZOHO_DB_PASSWORD=your-zoho-password
QUBO_ZOHO_DB_NAME=your-zoho-database
QUBO_ZOHO_TICKET_TABLE=Call_Driver_Data_Zoho_FromAug2024
QUBO_ZOHO_PRIMARY_KEY=Ticket_Id
QUBO_ZOHO_CREATED_COLUMN=Created_Time
QUBO_ZOHO_MODIFIED_COLUMN=Modified_Time
QUBO_SOURCE_START_DATE=2026-02-01

# ClickHouse analytics warehouse
QUBO_CLICKHOUSE_HOST=clickhouse
QUBO_CLICKHOUSE_PORT=8123
QUBO_CLICKHOUSE_USER=default
QUBO_CLICKHOUSE_PASSWORD=your-clickhouse-password
QUBO_CLICKHOUSE_DATABASE=qubo_analytics
QUBO_CLICKHOUSE_SECURE=false

QUBO_CLICKHOUSE_FACT_TABLE=tickets_fact_recent
QUBO_CLICKHOUSE_DAILY_SUMMARY_TABLE=tickets_daily_summary
QUBO_CLICKHOUSE_ISSUES_SUMMARY_TABLE=issues_daily_summary
QUBO_CLICKHOUSE_SYNC_STATE_TABLE=etl_sync_state
QUBO_CLICKHOUSE_RUN_LOG_TABLE=etl_run_log

QUBO_ETL_SCHEDULE=0 2 * * *
QUBO_ETL_TIMEZONE=Asia/Calcutta
QUBO_ETL_BATCH_SIZE=5000
QUBO_ETL_BACKFILL_DAYS=90
QUBO_ETL_OVERLAP_HOURS=24
QUBO_ETL_JOB_NAME=mysql_to_clickhouse

# Legacy MySQL aggregate warehouse fallback
QUBO_AGG_DB_HOST=127.0.0.1
QUBO_AGG_DB_PORT=3306
QUBO_AGG_DB_USER=your-agg-user
QUBO_AGG_DB_PASSWORD=your-agg-password
QUBO_AGG_DB_NAME=your-agg-database

QUBO_AGG_DAILY_TICKETS_TABLE=agg_daily_tickets
QUBO_AGG_FC_WEEKLY_TABLE=agg_fc_weekly
QUBO_AGG_SW_VERSION_TABLE=agg_sw_version
QUBO_AGG_RESOLUTION_TABLE=agg_resolution
QUBO_AGG_CHANNEL_TABLE=agg_channel
QUBO_AGG_BOT_TABLE=agg_bot
QUBO_AGG_HOURLY_HEATMAP_TABLE=agg_hourly_heatmap
QUBO_AGG_REPLACEMENTS_TABLE=agg_replacements
QUBO_AGG_VOC_MISMATCH_TABLE=agg_voc_mismatch
QUBO_AGG_ANOMALIES_TABLE=agg_anomalies
QUBO_AGG_HEALTH_SCORE_TABLE=agg_health_score
QUBO_AGG_DATA_QUALITY_TABLE=agg_data_quality
QUBO_PIPELINE_LOG_TABLE=pipeline_log
